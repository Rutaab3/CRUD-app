@model List<CRUD_app.Models.TimeTable>
@{
    ViewData["Title"] = "TimeTable";
}

<div class="text-center">
    <h1 class="display-4">Welcome222</h1>
    <p>@(Model?.Count)</p>
    <div>
        <h2 style="color: #1B3A6B">TimeTable List</h2>
        <p style="color: #6B7284">Total TimeTable <strong>@Model.Count</strong></p>

        <table style="width:100%; border-collapse:collapse">
            <tr style="background-color:#1B2A6B; color:white">
                <th style="padding:10px">Id</th>
                <th style="padding:10px">Name</th>
                <th style="padding:10px">Period</th>
                <th style="padding:10px">Days</th>
            </tr>

            @* foreach is C# inside HTML - it loops through every TimeTable *@
            @foreach (var TimeTable in Model)
            {
                <tr style="border-bottom:1px solid #E5E7EB;">
                    <td style="padding:10px">@TimeTable.Id</td>
                    <td style="padding:10px">@TimeTable.Name</td>
                    <td style="padding:10px">@TimeTable.Period</td>
                    <td style="padding:10px">@TimeTable.Days</td>
                </tr>
            }
        </table>
    </div>
</div>

